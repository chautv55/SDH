                    </div>
                </div>
            </div>
        </div>
        <div class="modal fade" id="Modal_alert" tabindex="-1" role="dialog"
            aria-hidden="true">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h4 class="modal-title text-primary">Thông báo</h4>
                    </div>
                    <div class="modal-body text-center">
                        <asp:Label ID="lb_nd_" Text="Bạn cần đăng nhập để truy cập chức năng này" CssClass="text-gray-900" runat="server"></asp:Label>
                    </div>
                    <div class="modal-footer">
                        <asp:LinkButton Text="Đăng nhập" ID="btn_call_dangnhap" OnClick="btn_call_dangnhap_Click" runat="server" />
                    </div>
                </div>
            </div>
        </div>
        <div class="modal fade" id="Modal_nophs" tabindex="-1" role="dialog"
            aria-hidden="true">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h4 class="modal-title text-primary">Thông báo</h4>
                    </div>
                    <div class="modal-body text-center">
                        <asp:Label ID="lbtb_hs" CssClass="text-gray-900" runat="server"></asp:Label>
                    </div>
                    <div class="modal-footer">
                        <asp:LinkButton Text="Tải hồ sơ" CssClass="btn btn-primary" ID="download_hs" OnClick="download_hs_Click" runat="server" />
                        <button class="btn btn-secondary" type="button" data-dismiss="modal">Đóng</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="Modal_doimk" tabindex="-1" role="dialog"
            aria-hidden="true">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h4 class="modal-title text-primary">Đổi mật khẩu</h4>
                    </div>
                    <asp:Panel runat="server" ID="pn_doimk" DefaultButton="btn_doimk">

                        <div class="modal-body text-center">

                            <div class="row mt-2">
                                <div class="col">
                                    Mật khẩu cũ
                                </div>
                                <div class="col">
                                    <asp:TextBox runat="server" ID="old_mk" CssClass="form-control" />
                                </div>
                            </div>
                            <div class="row mt-2">
                                <div class="col">
                                    Mật khẩu mới
                                </div>
                                <div class="col">
                                    <asp:TextBox runat="server" TextMode="Password" ID="new_mk" CssClass="form-control" />
                                </div>
                            </div>
                            <div class="row mt-2">
                                <div class="col">
                                    Nhập lại mật khẩu mới
                                </div>
                                <div class="col">
                                    <asp:TextBox runat="server" TextMode="Password" ID="new2_mk" CssClass="form-control" />
                                </div>
                            </div>

                        </div>
                        <div class="modal-footer">
                            <asp:Button Text="Xác nhận" CssClass="btn btn-primary" ID="btn_doimk" runat="server" OnClick="btn_doimk_Click" />
                            <button class="btn btn-secondary" type="button" data-dismiss="modal">Đóng</button>
                        </div>
                    </asp:Panel>

                </div>
            </div>
        </div>
        <div class="modal fade" id="Modal_dangxuat" tabindex="-1" role="dialog"
            aria-hidden="true">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h4 class="modal-title text-yellow-tvu">Xác nhận đăng xuất</h4>
                    </div>
                    <div class="modal-body text-center">
                        <asp:LinkButton Text="Xác nhận" CssClass="btn btn-primary" OnClick="btn_dx_Click" runat="server" />
                        <button class="btn btn-secondary" type="button" data-dismiss="modal">Đóng</button>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal fade" id="Modalguihs" tabindex="-1" role="dialog"
            aria-hidden="true">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h4 class="modal-title text-primary">Thông báo</h4>
                    </div>
                    <div class="modal-body text-center">
                        <asp:Label ID="Label1" CssClass="text-gray-900" Text="Đang gửi hồ sơ" runat="server"></asp:Label>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="modal " id="modal_gop_y" >
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h4 class="modal-title text-primary">Nội dung góp ý</h4>
                    </div>
                    <div class="modal-body text-center">
                        <asp:TextBox runat="server" CssClass="form-control" TextMode="MultiLine" ID="txt_gop_y" />
                    </div>
                    <div class="modal-footer">
                        <asp:Button Text="Gửi" ID="btn_gui_gopy" OnClick="btn_gui_gopy_Click" CssClass="btn btn-primary" runat="server" />
                        <button class="btn btn-secondary" type="button" data-dismiss="modal">Đóng</button>
                    </div>
                </div>
            </div>
        </div>
        <asp:LinkButton Text="" style="display:none" ID="btn_export_pdf" runat="server" />
        
    </form>
    <script>

        function click_view_btnexport() {
            document.getElementById('<%= btn_export_pdf.ClientID %>').click();
        }
        var summernoteData = {};
        Sys.WebForms.PageRequestManager.getInstance().add_initializeRequest(function (sender, args) {
            // Lưu dữ liệu Summernote trước partial postback
            $('.summernote').each(function () {
                var id = $(this).attr('id');
                summernoteData[id] = $(this).summernote('code');
            });

        });
        
        function pageLoad(sender, args) {
            if (args.get_isPartialLoad()) {
                // Reinitialize Chosen plugin after partial postback
                $(".select").chosen();
                $('.summernote').each(function () {
                    var id = $(this).attr('id');
                    var $this = $(this);
                    var content = summernoteData[id];
                    //var content = $this.summernote('code'); // Lưu nội dung
                    $this.summernote('destroy'); // Hủy khởi tạo cũ
                    $this.summernote(); // Khởi tạo lại
                    $this.summernote('code', content); // Khôi phục nội dung
                    summernoteData = {};
                });
                //$('.summernote').summernote();
            }
        }
        function close_Modal_alert() {
            $('#Modalalert').modal('hide');
            console.log('hide');
        }
        function Modalguihs() {
            var form = document.getElementById('<%= form1.ClientID%>');
            if (form.checkValidity()) {
                $('#Modalguihs').modal({ backdrop: 'static' });
                return true;
            }
            else {
                return false;
            }
        }
        function hideModalguihs() {
            $('#Modalguihs').modal('hide');
        }

        function post_(id) {
            __doPostBack(id.name, "");
            return false;
        }
        document.addEventListener("keydown", function (event) {
            // Kiểm tra nếu phím F5 được nhấn
            if (event.key === "F5" || event.keyCode === 116) {
                event.preventDefault(); // Ngăn trình duyệt thực hiện mặc định F5

                // Thực hiện tải lại trang mà không dùng cache
                window.location.reload(true);

            }
        });
        window.addEventListener("beforeunload", function (event) {
            console.log("Trang sắp được tải lại hoặc đóng.");
        });
    </script>
    <script src="assets/vendor/purecounter/purecounter_vanilla.js"></script>
    <script src="assets/vendor/aos/aos.js"></script>
    <script src="assets/vendor/swiper/swiper-bundle.min.js"></script>
    <script src="assets/js/main.js"></script>
