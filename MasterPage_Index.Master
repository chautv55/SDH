    <style>
        
        .resize{
            font-size:clamp(10px, 3vw, 21px);
        }
        .header-fix {
            top: 0px;
            position: sticky;
            z-index: 10;
            background-color: white;
        }
        .logo{
            width: 100%; 
        }
        .border-bottom-tvu {
            /*border-top: 7px solid #121260;*/
            /*border-bottom: 7px solid #121260;*/
            border-bottom: 20px solid transparent;
            border-image: url('Data/img/border-bottom.png') 30 stretch;
            border-image-slice: 0 0 30 0; /* Chỉ lấy phần dưới */
        }
        .zalo-icon {
            position: fixed;
            bottom: 20px;
            right: 20px;
            border-radius: 50%;
            width: 60px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            transition: transform 0.3s;
            overflow: hidden; /* Đảm bảo ảnh không vượt quá vòng tròn */
        }

            .zalo-icon a img {
                width: 80%; /* Điều chỉnh kích thước ảnh để vừa trong vòng tròn */
                height: 80%;
                object-fit: cover; /* Giúp ảnh co dãn phù hợp mà không làm biến dạng */
                border-radius: 50%;
            }
        .btn-lienket {
            font-weight: 700;
            border: 3px solid blue;
            width: 100%;
            background-color: white;
            color: darkgreen;
            font-size: 18pt;
            line-height: 2;
            text-align: left;
        }

            .btn-lienket:hover {
                background-color: darkblue;
                color: white;
            }

    </style>
</head>
<body>
    <form id="form1" runat="server" onreset="event.preventDefault();">
        <asp:ScriptManager runat="server" />
        <script>
            $(function () {
                $(".select").chosen();
                $('.summernote').summernote();
            });
            //function openModal_alert(texttb) {
            //    $('#Modal_alert').modal({ backdrop: 'static' });
            //}
            function openModalalert(texttb) {
                $('#Modalalert').modal({ backdrop: 'static' });
                //console.log(document.getElementById('master_tb'));
                document.getElementById('master_tb').innerHTML = texttb;
            }
            
            function openModal_nophs(texttb) {
                $('#Modal_nophs').modal({ backdrop: 'static' });
                document.getElementById('lbtb_hs').innerHTML = texttb;
            }
            function show_openModal_tb() {
                $('#Modal_show_tb').modal({ backdrop: 'static' });
            }
            $('.search_textbox').each(function (i) {
                $(this).quicksearch("[id*=gv_dslop] tr:not(:has(th))", {
                    'testQuery': function (query, txt, row) {
                        return $(row).children(":eq(" + (i + 1) + ")").text().toLowerCase().indexOf(query[0].toLowerCase()) != -1;
                    }
                });
            });
            //window.onload = function () {
            //    if (window.location.href.indexOf('refresh=true') === -1) {
            //        window.location.href = window.location.href + (window.location.href.indexOf('?') === -1 ? '?' : '&') + 'refresh=true';
            //    }
            //};
            function openNewTab(url) {
                var win = window.open(url, '_blank');
                win.focus();
            }
            document.addEventListener("DOMContentLoaded", function () {
                const dropdowns = document.querySelectorAll(".navbar .dropdown .dropdown");

                dropdowns.forEach(function (dropdown) {
                    {
                        const menu = dropdown.querySelector("ul");

                        if (!menu) return;

                        // Tạm hiện menu để đo
                        menu.style.visibility = 'hidden';
                        menu.style.display = 'block';
                        const rect = menu.getBoundingClientRect();

                        // Nếu tràn phải → thêm class dropdown-left
                        if (rect.right > window.innerWidth) {
                            menu.style.left = "auto";
                            menu.style.right = "calc(100%)";
                            menu.style.top = "-5px";
                            change_left(menu);
                        }

                        // Reset hiển thị
                        menu.style.visibility = '';
                        menu.style.display = '';
                    }
                });
            });
            function load_nav() {

            }
            function change_left(menu) {
                const dropdowns = menu.querySelectorAll(".dropdown");
                if (!dropdowns) return;
                dropdowns.forEach(function (dropdown) {
                    dropdown.addEventListener("mouseenter", function () {
                        const menu = dropdown.querySelector("ul");
                        if (!menu) return;
                        // Nếu tràn phải → thêm class dropdown-left
                        menu.style.left = "auto";
                        menu.style.right = "calc(100%)";
                        menu.style.top = "-5px";
                        change_left(menu);
                    });
                });
            }
        </script>
       
